<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Website Pertamaku</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            margin:0;
            background:#f4f4f4;
        }

        header{
            background:#2196f3;
            color:white;
            padding:15px;
            text-align:center;
        }

        nav{
            background:#333;
            padding:10px;
            text-align:center;
        }

        nav a{
            color:white;
            text-decoration:none;
            margin:10px;
            font-weight:bold;
        }

        nav a:hover{
            color:yellow;
        }

        .content{
            padding:30px;
            text-align:center;
        }

        button{
            padding:10px 20px;
            background:#2196f3;
            border:none;
            color:white;
            font-size:16px;
            border-radius:5px;
            cursor:pointer;
        }

        button:hover{
            background:#0b7dda;
        }

        footer{
            background:#333;
            color:white;
            text-align:center;
            padding:10px;
            margin-top:30px;
        }
    </style>
</head>

<body>

<header>
    <h1>Website Saya</h1>
    <p>Belajar membuat website</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">Tentang</a>
    <a href="#">Kontak</a>
</nav>

<div class="content">
    <h2>website danu</h2>
    <p>halo tan.</p>

    <button onclick="halo()">Klik Saya</button>
</div>

<footer>
    <p>© 2026 Website Saya</p>
</footer>

<script>
function halo(){
    alert("Halo! Terima kasih sudah mengunjungi website ini 😀");
}
</script>

</body>
</html>